# ─── Base de données ───────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=super8
DB_USER=super8
DB_PASSWORD=changeme

# Mot de passe root MySQL (uniquement pour l'init Docker)
DB_ROOT_PASSWORD=changeme_root

# ─── Application ───────────────────────────────────────────────
# Mot de passe de l'interface d'administration (/admin)
ADMIN_PASSWORD=changeme_admin

# Secret JWT — générer avec : openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret

# ─── Ports ─────────────────────────────────────────────────────
APP_PORT=3000
VIDEOS_PORT=3001
